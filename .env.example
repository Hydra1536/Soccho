DEBUG=true
DATABASE_URL= your_database_url_here
RENDER_INTERNAL_REDIS_URL=redis://redis:6379
REDIS_CACHE_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
CHANNEL_LAYERS_REDIS_URL=redis://redis:6379/2

AES_SECRET_KEY=replace_aes_secret_key
AUTH_SECRET_KEY=replace_auth_secret_key
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
SOCIAL_SECRET_KEY=replace_social_secret_key
TRANSACTION_SECRET_KEY=replace_transaction_secret_key
NOTIFICATION_SECRET_KEY=replace_notification_secret_key
ADMIN_SECRET_KEY=replace_admin_secret_key
GATEWAY_SECRET_KEY=replace_gateway_secret_key

AUTH_HTTP_BASE_URL=https://soccho-auth.onrender.com
SOCIAL_HTTP_BASE_URL=https://soccho-social.onrender.com
TRANSACTION_HTTP_BASE_URL=https://soccho-transaction.onrender.com
NOTIFICATION_HTTP_BASE_URL=https://soccho-notification.onrender.com

ALLOWED_ORIGINS=https://soccho.onrender.com,https://soccho.vercel.app
AXES_ENABLED=false
ADMIN_URL_PATH=replace_admin_url_path/
GOOGLE_CLIENT_ID=replace_google_client_id
GOOGLE_CLIENT_SECRET=replace_google_client_secret
