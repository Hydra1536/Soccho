KEEPALIVE_ENABLED=true
KEEPALIVE_INTERVAL_SECONDS=600
KEEPALIVE_TIMEOUT_SECONDS=15
KEEPALIVE_JITTER_SECONDS=0
KEEPALIVE_TARGETS=https://soccho-gateway.onrender.com/healthz,https://soccho-auth.onrender.com/api/auth/health/,https://soccho-social.onrender.com/health/,https://soccho-transaction.onrender.com/health/,https://soccho-notification.onrender.com/health/
PYTHON_VERSION=3.12.3
